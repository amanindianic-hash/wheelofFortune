# Neon PostgreSQL — get from https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# JWT secret — at least 32 random characters
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# App public URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — get keys from https://dashboard.stripe.com/apikeys
# Leave blank to disable paid plan checkout (plans will show an error message)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create products at https://dashboard.stripe.com/products
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yoursite.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # same as VAPID_PUBLIC_KEY

# Twilio WhatsApp Business API
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Google Wallet
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_CLASS_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=   # base64-encoded service account JSON

# Apple Wallet
APPLE_PASS_TYPE_ID=
APPLE_TEAM_ID=
APPLE_PASS_CERT=    # base64-encoded PEM
APPLE_PASS_KEY=     # base64-encoded PEM
APPLE_WWDR_CERT=    # base64-encoded PEM

# Cron secret (for securing cron endpoints)
CRON_SECRET=
